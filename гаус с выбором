
A = [2, 1, -1;
    -3, -1, 2;
    -2, 1, 2];
b = [8; -11; -3];

[n, ~] = size(A);
Ab = [A, b]; 
Ab(i:n, i)

for i = 1:n
    [~, max_idx] = max(abs(Ab(i:n, i)));
    max_idx = max_idx + i - 1;
    
    Ab([i, max_idx], :) = Ab([max_idx, i], :);
    

    for j = i+1:n
        factor = Ab(j, i) / Ab(i, i);
        Ab(j, i:end) = Ab(j, i:end) - factor * Ab(i, i:end);
    end
end


x = zeros(n, 1);
for i = n:-1:1
    x(i) = (Ab(i, end) - Ab(i, i+1:n) * x(i+1:n)) / Ab(i, i);
end

x

A\b
